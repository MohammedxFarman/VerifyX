{
  "manifest_version": 3,
  "name": "VerifyX - Trust Scanner",
  "version": "1.0.0",
  "description": "Verify Everything. Trust Confidently. AI-powered trust analyzer for websites, content, and media.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "clipboardRead"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
